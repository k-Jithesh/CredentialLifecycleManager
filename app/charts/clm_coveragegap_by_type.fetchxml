<fetch version="1.0" mapping="logical" aggregate="true">
  <entity name="clm_coveragegap">
    <attribute name="clm_coveragegapid" alias="count_col" aggregate="countcolumn" />
    <attribute name="clm_gaptype" alias="groupby_col" groupby="true" />
    <order alias="groupby_col" descending="false" />
    <filter type="and">
      <condition attribute="clm_status" operator="eq" value="950000000" />
    </filter>
  </entity>
</fetch>
