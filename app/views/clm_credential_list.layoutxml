<grid name="resultset" object="0" jump="clm_name" select="1" icon="1" preview="1">
  <row name="result" id="clm_credentialid">
    <cell name="clm_name" width="220" />
    <cell name="clm_sourcesystem" width="170" />
    <cell name="clm_credentialtype" width="140" />
    <cell name="clm_expirydate" width="140" />
    <cell name="clm_status" width="120" />
    <cell name="clm_owneruser" width="180" />
    <cell name="clm_environment" width="180" />
  </row>
</grid>
