{
  "properties": {
    "connectionParameters": {
      "token": {
        "type": "oauthSetting",
        "oAuthSettings": {
          "identityProvider": "aad",
          "clientId": "<CLIENT_ID>",
          "scopes": [
            "https://graph.microsoft.com/.default"
          ],
          "redirectMode": "Global",
          "redirectUrl": "https://global.consent.azure-apim.net/redirect",
          "properties": {
            "IsFirstParty": "False",
            "AzureActiveDirectoryResourceId": "https://graph.microsoft.com",
            "IsOnbehalfofLoginSupported": false
          },
          "customParameters": {
            "loginUri": {
              "value": "https://login.microsoftonline.com"
            },
            "tenantId": {
              "value": "<TENANT_ID>"
            },
            "resourceUri": {
              "value": "https://graph.microsoft.com"
            },
            "enableOnbehalfOfLogin": {
              "value": "false"
            }
          }
        },
        "uiDefinition": {
          "displayName": "AAD (Graph)",
          "description": "Sign in with an account that has admin-consented the CLM Discovery app.",
          "tooltip": "Use a service account for unattended Cloud Flows.",
          "constraints": {
            "required": "true"
          }
        }
      }
    },
    "iconBrandColor": "#1F3A93",
    "capabilities": [
      "actions"
    ],
    "publisher": "CLM Platform Ops",
    "stackOwner": "CLM Platform Ops",
    "policyTemplateInstances": [
      {
        "templateId": "setheader",
        "title": "Inject ConsistencyLevel for Graph advanced queries",
        "parameters": {
          "x-ms-apimTemplateParameter.name": "ConsistencyLevel",
          "x-ms-apimTemplateParameter.value": "eventual",
          "x-ms-apimTemplateParameter.existsAction": "override",
          "x-ms-apimTemplate-policySection": "Request"
        }
      }
    ]
  }
}
